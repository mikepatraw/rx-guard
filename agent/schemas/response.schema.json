{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RedParrotBerkeley/rx-guard/blob/main/agent/schemas/response.schema.json",
  "title": "RX Guard Review Response",
  "description": "Structured response schema for RX Guard prescribing safety review results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "riskLevel",
    "summary",
    "flags",
    "missingDocumentation",
    "suggestedLanguage",
    "pdmpCrossReference",
    "metadata"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["review_complete", "partial_review", "input_error"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "moderate", "high", "unknown"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "source", "message", "explanation"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["low", "moderate", "high"]
          },
          "source": {
            "type": "string",
            "enum": ["rules", "ai", "merged"]
          },
          "message": { "type": "string", "minLength": 1 },
          "explanation": { "type": "string", "minLength": 1 }
        }
      },
      "default": []
    },
    "missingDocumentation": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "suggestedLanguage": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "pdmpCrossReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched", "totalPrescriptions", "prescriberCount90d", "pharmacyCount90d", "activeOverlaps"],
      "properties": {
        "matched": { "type": "boolean" },
        "name": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "totalPrescriptions": { "type": "integer", "minimum": 0 },
        "prescriberCount90d": { "type": "integer", "minimum": 0 },
        "pharmacyCount90d": { "type": "integer", "minimum": 0 },
        "lastFillDate": { "type": "string", "format": "date" },
        "activeOverlaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["medA", "medB", "date"],
            "properties": {
              "medA": { "type": "string" },
              "medB": { "type": "string" },
              "date": { "type": "string", "format": "date" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic", "version"],
      "properties": {
        "synthetic": { "type": "boolean" },
        "version": { "type": "string", "minLength": 1 },
        "requestId": { "type": "string" },
        "reviewMode": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
